<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Journal & Calculator</title>
    <style>
        :root {
            --bg-color: #0b0f19;
            --card-bg: #151c2c;
            --card-border: #232d42;
            --accent: #38bdf8;
            --accent-hover: #0284c7;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --win-color: #22c55e;
            --loss-color: #ef4444;
            --be-color: #eab308;
            --radius: 10px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            padding: 15px;
            line-height: 1.5;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
        }

        header {
            display: flex;
            flex-direction: column;
            gap: 15px;
            border-bottom: 2px solid var(--card-border);
            padding-bottom: 20px;
            margin-bottom: 25px;
        }

        @media(min-width: 768px) {
            header {
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }
        }

        h1 {
            font-size: 1.6rem;
            color: var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius);
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
        }

        .card h2 {
            font-size: 1.1rem;
            color: var(--accent);
            margin-bottom: 15px;
            border-bottom: 1px solid var(--card-border);
            padding-bottom: 8px;
        }

        /* GRID RESPONSIVE */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
        }

        @media(min-width: 600px) {
            .form-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media(min-width: 900px) {
            .form-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .full-width {
            grid-column: 1 / -1;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        label {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 600;
        }

        input, select, textarea {
            background-color: var(--bg-color);
            border: 1px solid var(--card-border);
            color: var(--text-main);
            padding: 12px;
            border-radius: 6px;
            font-size: 0.95rem;
            width: 100%;
            transition: border-color 0.2s;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--accent);
        }

        /* BUTTONS */
        .actions-bar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 15px;
        }

        button {
            padding: 10px 16px;
            border-radius: 6px;
            border: none;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background-color 0.2s, opacity 0.2s;
        }

        button:active {
            transform: scale(0.98);
        }

        .btn-primary { background-color: var(--accent); color: #0b0f19; }
        .btn-primary:hover { background-color: var(--accent-hover); color: #fff; }
        .btn-excel { background-color: #107c41; color: #fff; }
        .btn-secondary { background-color: var(--card-border); color: var(--text-main); }
        .btn-danger { background-color: var(--loss-color); color: #fff; }

        /* DASHBOARD STATS */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        @media(min-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .stat-card {
            background-color: var(--bg-color);
            border: 1px solid var(--card-border);
            padding: 12px 15px;
            border-radius: 8px;
            text-align: center;
        }

        .stat-card .val {
            font-size: 1.4rem;
            font-weight: bold;
            color: var(--accent);
            margin-top: 4px;
        }

        .stat-card .lbl {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        /* RESULT BOX */
        .result-box {
            background-color: rgba(56, 189, 248, 0.08);
            border: 1px dashed var(--accent);
            padding: 12px;
            border-radius: 8px;
            margin-top: 15px;
            text-align: center;
        }

        /* TABLE */
        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
            min-width: 650px;
        }

        th, td {
            padding: 10px 12px;
            text-align: left;
            border-bottom: 1px solid var(--card-border);
        }

        th {
            background-color: rgba(255, 255, 255, 0.02);
            color: var(--text-muted);
        }

        .badge {
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 0.75rem;
        }

        .badge-win { background-color: rgba(34, 197, 94, 0.15); color: var(--win-color); }
        .badge-loss { background-color: rgba(239, 68, 68, 0.15); color: var(--loss-color); }
        .badge-be { background-color: rgba(234, 179, 8, 0.15); color: var(--be-color); }

        .img-thumb {
            width: 40px;
            height: 40px;
            border-radius: 4px;
            object-fit: cover;
            cursor: pointer;
            border: 1px solid var(--card-border);
        }

        /* MODALE FOTO */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.85);
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal img {
            max-width: 90%;
            max-height: 85vh;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>📊 Trading Journal & Tools</h1>
        <div class="actions-bar" style="margin-top:0;">
            <button class="btn-excel" onclick="exportCSV()">📥 Esporta Report (.csv)</button>
            <button class="btn-secondary" onclick="exportJSON()">💾 Backup JSON</button>
            <input type="file" id="importFile" accept=".json" style="display:none" onchange="importJSON(event)">
            <button class="btn-secondary" onclick="document.getElementById('importFile').click()">📂 Carica Backup</button>
        </div>
    </header>

    <!-- DASHBOARD STATISTICHE -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="lbl">Trade Totali</div>
            <div class="val" id="statTotal">0</div>
        </div>
        <div class="stat-card">
            <div class="lbl">Win Rate</div>
            <div class="val" id="statWinRate">0%</div>
        </div>
        <div class="stat-card">
            <div class="lbl">Esiti (W / L / BE)</div>
            <div class="val" id="statWLB" style="font-size:1.1rem; margin-top:8px;">0 / 0 / 0</div>
        </div>
        <div class="stat-card">
            <div class="lbl">R:R Cumulativo</div>
            <div class="val" id="statRR">0 R</div>
        </div>
    </div>

    <!-- SEZIONE CALCOLATORE LOTTAGGIO -->
    <div class="card">
        <h2>🧮 Calcolatore Lottaggio Posizione</h2>
        <div class="form-grid">
            <div class="form-group">
                <label for="calcBalance">Capitale Conto (€ / $)</label>
                <input type="number" id="calcBalance" value="10000" placeholder="10000">
            </div>
            <div class="form-group">
                <label for="calcRisk">Rischio (%)</label>
                <input type="number" id="calcRisk" step="0.1" value="1" placeholder="1">
            </div>
            <div class="form-group">
                <label for="calcSlPips">Stop Loss (Pips / Punti)</label>
                <input type="number" id="calcSlPips" value="20" placeholder="20">
            </div>
            <div class="form-group">
                <label for="calcAssetType">Tipo di Asset</label>
                <select id="calcAssetType">
                    <option value="forex">Forex Standard (1 Lotto = 10$/pip)</option>
                    <option value="crypto_index">Indici / Crypto / Azioni</option>
                </select>
            </div>
        </div>
        <div class="actions-bar">
            <button type="button" class="btn-primary" onclick="calculateLotSize()">⚡ Calcola Dimensione Posizione</button>
        </div>
        <div id="calcResult" class="result-box" style="display:none;">
            Taglia Posizione Consigliata: <strong id="lotResultText" style="color:var(--accent); font-size: 1.2rem;">0.00</strong> Lotti
            <div id="riskAmountText" style="font-size:0.85rem; color:var(--text-muted); margin-top:4px;"></div>
        </div>
    </div>

    <!-- FORM INSERIMENTO TRADE -->
    <div class="card">
        <h2>📝 Nuova Operazione</h2>
        <form id="tradeForm">
            <div class="form-grid">
                <div class="form-group">
                    <label for="date">Data Operazione</label>
                    <input type="date" id="date" required>
                </div>
                <div class="form-group">
                    <label for="asset">Asset / Coppia</label>
                    <input type="text" id="asset" placeholder="es. EUR/USD, Oro, BTC" required>
                </div>
                <div class="form-group">
                    <label for="strategy">Nome Strategia</label>
                    <input type="text" id="strategy" placeholder="es. Breakout, Scalping" required>
                </div>
                <div class="form-group">
                    <label for="direction">Direzione</label>
                    <select id="direction">
                        <option value="LONG">LONG 📈</option>
                        <option value="SHORT">SHORT 📉</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="result">Esito Trade</label>
                    <select id="result">
                        <option value="WIN">WIN 🟢</option>
                        <option value="LOSS">LOSS 🔴</option>
                        <option value="BE">BE 🟡</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="rr">R : R (Rischio / Rendimento)</label>
                    <select id="rr" required>
                        <option value="1:0.5">1 : 0.5</option>
                        <option value="1:1">1 : 1</option>
                        <option value="1:1.5">1 : 1.5</option>
                        <option value="1:2" selected>1 : 2</option>
                        <option value="1:2.5">1 : 2.5</option>
                        <option value="1:3">1 : 3</option>
                        <option value="1:4">1 : 4</option>
                        <option value="1:5">1 : 5</option>
                        <option value="1:6">1 : 6+</option>
                    </select>
                </div>
                <div class="form-group full-width">
                    <label for="imageFile">Screenshot (Galleria / Foto)</label>
                    <input type="file" id="imageFile" accept="image/*">
                </div>
                <div class="form-group full-width">
                    <label for="notes">Note / Confluenze</label>
                    <textarea id="notes" rows="2" placeholder="Motivazioni dell'ingresso, emozioni, condizioni di mercato..."></textarea>
                </div>
            </div>
            <div class="actions-bar">
                <button type="submit" class="btn-primary">💾 Salva Trade nel Journal</button>
            </div>
        </form>
    </div>

    <!-- TABELLA STORICO -->
    <div class="card">
        <h2>📋 Storico Operazioni</h2>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Asset</th>
                        <th>Strategia</th>
                        <th>Direzione</th>
                        <th>Esito</th>
                        <th>R:R</th>
                        <th>Foto</th>
                        <th>Note</th>
                        <th>Azione</th>
                    </tr>
                </thead>
                <tbody id="tradeTableBody">
                    <!-- Trade dinamici -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODALE INGRANDIMENTO FOTO -->
<div id="imgModal" class="modal" onclick="this.style.display='none'">
    <img id="modalImg" src="" alt="Zoom Screenshot">
</div>

<script>
    // Inizializzazione Data odierna
    document.getElementById('date').valueAsDate = new Date();
    
    // Recupero Dati
    let trades = JSON.parse(localStorage.getItem('trading_journal_data')) || [];

    // --- CALCOLATORE LOTTAGGIO ---
    function calculateLotSize() {
        const balance = parseFloat(document.getElementById('calcBalance').value);
        const riskPercent = parseFloat(document.getElementById('calcRisk').value);
        const slPips = parseFloat(document.getElementById('calcSlPips').value);
        const assetType = document.getElementById('calcAssetType').value;

        if (!balance || !riskPercent || !slPips || slPips <= 0) {
            alert("Compila tutti i campi del calcolatore con valori maggiori di zero.");
            return;
        }

        const riskAmount = balance * (riskPercent / 100);
        let lotSize = (assetType === 'forex') ? (riskAmount / (slPips * 10)) : (riskAmount / slPips);

        document.getElementById('lotResultText').innerText = lotSize.toFixed(2);
        document.getElementById('riskAmountText').innerText = `Rischio Monetario Effettivo: ${riskAmount.toFixed(2)} €/$`;
        document.getElementById('calcResult').style.display = 'block';
    }

    // --- COMPRESSIONE FOTO PER PREVENIRE CRASH CHROME ---
    function fileToBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (e) => {
                const img = new Image();
                img.src = e.target.result;
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    const MAX_WIDTH = 1000;
                    let scale = 1;
                    
                    if (img.width > MAX_WIDTH) {
                        scale = MAX_WIDTH / img.width;
                    }

                    canvas.width = img.width * scale;
                    canvas.height = img.height * scale;

                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    resolve(canvas.toDataURL('image/jpeg', 0.7)); 
                };
                img.onerror = error => reject(error);
            };
            reader.onerror = error => reject(error);
        });
    }

    // --- CALCOLO STATISTICHE ---
    function updateStats() {
        const total = trades.length;
        if (total === 0) {
            document.getElementById('statTotal').innerText = "0";
            document.getElementById('statWinRate').innerText = "0%";
            document.getElementById('statWLB').innerText = "0 / 0 / 0";
            document.getElementById('statRR').innerText = "0 R";
            return;
        }

        let wins = 0, losses = 0, be = 0, totalRR = 0;

        trades.forEach(t => {
            if (t.result === 'WIN') {
                wins++;
                const rrVal = parseFloat(t.rr.replace('1:', '')) || 1;
                totalRR += rrVal;
            } else if (t.result === 'LOSS') {
                losses++;
                totalRR -= 1;
            } else {
                be++;
            }
        });

        const winRate = Math.round((wins / total) * 100);

        document.getElementById('statTotal').innerText = total;
        document.getElementById('statWinRate').innerText = `${winRate}%`;
        document.getElementById('statWLB').innerText = `${wins} / ${losses} / ${be}`;
        document.getElementById('statRR').innerText = `${totalRR >= 0 ? '+' : ''}${totalRR.toFixed(1)} R`;
    }

    // --- RENDERING TABELLA ---
    function renderTrades() {
        const tbody = document.getElementById('tradeTableBody');
        tbody.innerHTML = '';

        if (trades.length === 0) {
            tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; color:var(--text-muted); padding:20px;">Nessun trade salvato finora.</td></tr>`;
            updateStats();
            return;
        }

        trades.forEach((trade, index) => {
            const tr = document.createElement('tr');

            let badgeClass = 'badge-win';
            if (trade.result === 'LOSS') badgeClass = 'badge-loss';
            if (trade.result === 'BE') badgeClass = 'badge-be';

            const imgHtml = trade.image 
                ? `<img src="${trade.image}" class="img-thumb" onclick="openModal('${trade.image}')" alt="Grafico">` 
                : '-';

            tr.innerHTML = `
                <td>${trade.date}</td>
                <td><strong>${trade.asset}</strong></td>
                <td>${trade.strategy}</td>
                <td>${trade.direction}</td>
                <td><span class="badge ${badgeClass}">${trade.result}</span></td>
                <td>${trade.rr}</td>
                <td>${imgHtml}</td>
                <td>${trade.notes || '-'}</td>
                <td><button class="btn-danger" style="padding:4px 8px; font-size:0.75rem;" onclick="deleteTrade(${index})">🗑️</button></td>
            `;
            tbody.appendChild(tr);
        });

        updateStats();
    }

    // --- AGGIUNTA NUOVO TRADE ---
    document.getElementById('tradeForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        let imageData = "";
        const fileInput = document.getElementById('imageFile');
        if (fileInput.files && fileInput.files[0]) {
            try {
                imageData = await fileToBase64(fileInput.files[0]);
            } catch (err) {
                console.error("Errore caricamento foto", err);
            }
        }

        const newTrade = {
            date: document.getElementById('date').value,
            asset: document.getElementById('asset').value.toUpperCase().trim(),
            strategy: document.getElementById('strategy').value.trim(),
            direction: document.getElementById('direction').value,
            result: document.getElementById('result').value,
            rr: document.getElementById('rr').value,
            image: imageData,
            notes: document.getElementById('notes').value.trim()
        };

        trades.unshift(newTrade);
        saveData();
        renderTrades();

        this.reset();
        document.getElementById('date').valueAsDate = new Date();
    });

    // --- SALVATAGGIO LOCALE ---
    function saveData() {
        localStorage.setItem('trading_journal_data', JSON.stringify(trades));
    }

    // --- ELIMINAZIONE TRADE ---
    function deleteTrade(index) {
        if (confirm("Sei sicuro di voler eliminare questo trade?")) {
            trades.splice(index, 1);
            saveData();
            renderTrades();
        }
    }

    // --- VISORE FOTO ---
    function openModal(imgSrc) {
        document.getElementById('modalImg').src = imgSrc;
        document.getElementById('imgModal').style.display = 'flex';
    }

    // --- ESPORTAZIONE CSV / EXCEL BLOB ---
    function exportCSV() {
        if (trades.length === 0) {
            alert("Non ci sono operazioni da esportare!");
            return;
        }

        let csvRows = ["Data,Asset,Strategia,Direzione,Esito,RR,Note"];
        
        trades.forEach(t => {
            const cleanNotes = (t.notes || '').replace(/"/g, '""').replace(/\n/g, ' ');
            const row = `"${t.date}","${t.asset}","${t.strategy}","${t.direction}","${t.result}","${t.rr}","${cleanNotes}"`;
            csvRows.push(row);
        });

        const csvString = csvRows.join("\n");
        const blob = new Blob([csvString], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        
        const link = document.createElement("a");
        link.href = url;
        link.setAttribute("download", `Trading_Journal_${new Date().toISOString().slice(0,10)}.csv`);
        document.body.appendChild(link);
        link.click();
        
        setTimeout(() => {
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        }, 100);
    }

    // --- BACKUP E RIPRISTINO JSON BLOB ---
    function exportJSON() {
        if (trades.length === 0) {
            alert("Non ci sono dati da salvare nel backup!");
            return;
        }

        const jsonString = JSON.stringify(trades, null, 2);
        const blob = new Blob([jsonString], { type: 'application/json' });
        const url = URL.createObjectURL(blob);

        const link = document.createElement('a');
        link.href = url;
        link.setAttribute("download", `trading_journal_backup_${new Date().toISOString().slice(0,10)}.json`);
        document.body.appendChild(link);
        link.click();

        setTimeout(() => {
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        }, 100);
    }

    function importJSON(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const imported = JSON.parse(e.target.result);
                if (Array.isArray(imported)) {
                    trades = imported;
                    saveData();
                    renderTrades();
                    alert("Backup ripristinato con successo!");
                } else {
                    alert("Il file non contiene un backup valido.");
                }
            } catch (err) {
                alert("Errore durante la lettura del file di backup.");
            }
            event.target.value = '';
        };

        reader.readAsText(file);
    }

    // Primo caricamento
    renderTrades();
</script>

</body>
</html>
